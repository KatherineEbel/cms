<ul class="index">
  <% @files.each do |file| %>
    <li>
      <a href="/<%= file %>"><%= file %></a>
      <a href="/<%= file %>/edit">Edit</a>
      <form action="/<%= file %>/delete" method="post">
        <button type="submit">Delete</button>
      </form>
      <a href="/<%= file %>/delete">Delete</a>
    </li>
    <% end %>
</ul>
<p><a href="/new">New Document</a></p>
