<!doctype html>
<html lang="en-US">
  <head>
    <title>CMS</title>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/stylesheets/whitespace-reset.css">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>
  <body>
    <% if session[:message] %>
      <div class="flash-message">
        <p>
          <%= session.delete(:message) %>
        </p>
      </div>
    <% end %>
    <%= yield %>  
  </body>
</html>
